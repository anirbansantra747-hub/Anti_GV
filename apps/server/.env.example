# Server Environment Variables
# Copy this to .env and fill in your values

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/antigv

# ==========================================
# AI Provider Control Plane
# ==========================================

# [PRIMARY INTERACTIVE PATH]
# Used for: Intent Classification, Task Briefs, Planning, Chat, fast fallback.
# Target Model: llama-3.3-70b-versatile
GROQ_API_KEY=gsk_your_key_here

# [SECONDARY CODE & REASONING PATH]
# Used for: Code Generation (STEP_CODEGEN), heavy reasoning, deep patch generation.
# Target Models: meta/llama-3.3-70b-instruct, ibm/granite-34b-code-instruct
NVIDIA_API_KEY=nvapi-your_key_here

# [BROKERED OVERFLOW / FAILOVER]
# Used for: Free-tier first failover and model experimentation.
# Target Model: openai/gpt-oss-20b:free
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# [EVALUATION & SHADOW TESTING]
# Used for: Async regression suites, evaluation, verification.
# Target Model: gpt-4.1-mini
GITHUB_MODELS_API_KEY=github_pat_your_token_here

# [LEGACY & EXPERIMENTAL]
CEREBRAS_API_KEY=csk-your_key_here
GEMINI_API_KEY=AIza_your_key_here

# Vector DB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_SSL=false
PINECONE_API_KEY=pcsk_your_key_here

# Embeddings (local)
EMBEDDING_URL=http://localhost:8001/embed
EMBEDDING_INFO_URL=http://localhost:8001/info
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=8
EMBEDDING_MAX_CHARS=8000
INDEXER_DEBUG=false
INDEXER_MAX_FILE_BYTES=1000000
INDEXER_MAX_CHUNKS_PER_FILE=200
INDEXER_HASH_BYTES=131072
CHUNK_BUDGET=10000
CHAT_MAX_MESSAGES=12

# JWT
JWT_SECRET=change-this-to-a-random-string
JWT_EXPIRES_IN=7d

# Judge0 Code Execution
JUDGE0_URL=http://localhost:2358
JUDGE0_API_KEY=your_key_here

# Client
CLIENT_URL=http://localhost:5173

# Server
PORT=3001

# Docker Code Runner
DOCKER_RUN_TIMEOUT_MS=10000
DOCKER_MEMORY_LIMIT=256m
DOCKER_CPU_LIMIT=0.5

# Docker Images
DOCKER_JAVA_IMAGE=antigv-java-runner:latest
DOCKER_NODE_IMAGE=antigv-node-runner:latest
DOCKER_PYTHON_IMAGE=antigv-python-runner:latest
DOCKER_GCC_IMAGE=antigv-gcc-runner:latest
DOCKER_GO_IMAGE=antigv-go-runner:latest
DOCKER_RUST_IMAGE=antigv-rust-runner:latest
DOCKER_RUBY_IMAGE=antigv-ruby-runner:latest
DOCKER_PHP_IMAGE=antigv-php-runner:latest
DOCKER_DOTNET_IMAGE=antigv-dotnet-runner:latest
DOCKER_KOTLIN_IMAGE=antigv-kotlin-runner:latest
DOCKER_BASH_IMAGE=antigv-bash-runner:latest
